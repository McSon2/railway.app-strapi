{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": { "i18n": { "localized": true } },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "excerpt": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "featuredImage": {
      "type": "media",
      "allowedTypes": ["images"],
      "multiple": false,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slotName": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "providerName": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "providerLogo": {
      "type": "media",
      "allowedTypes": ["images"],
      "multiple": false,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "rtp": {
      "type": "decimal",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "volatility": {
      "type": "enumeration",
      "enum": ["low", "medium", "medium-high", "high", "extreme"],
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "maxWin": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "minBet": {
      "type": "decimal",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "maxBet": {
      "type": "decimal",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "paylines": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "releaseDate": {
      "type": "date",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "theme": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "features": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "ctaLabel": {
      "type": "string",
      "default": "Jouer maintenant",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "ctaUrl": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "subtitle": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "personalOpinion": {
      "type": "blocks",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "mechanicsContent": {
      "type": "blocks",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "youtubeVideos": {
      "type": "component",
      "repeatable": true,
      "component": "shared.youtube-video",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "youtubePlaylistUrl": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "faq": {
      "type": "component",
      "repeatable": true,
      "component": "shared.faq-item",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "casinos": {
      "type": "component",
      "repeatable": true,
      "component": "shared.casino-option",
      "pluginOptions": { "i18n": { "localized": true } }
    }
  }
}
